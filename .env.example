# Copy to .env before running docker compose.
# Use URL-safe values for POSTGRES_PASSWORD because it is embedded in DATABASE_URL.

POSTGRES_PASSWORD=change-me-url-safe-db-password
APR_PUBLIC_DOMAIN=reliability.hihongrun.com
PUBLIC_BASE_URL=http://localhost:8787
DASHBOARD_PORT=8787

APR_ADMIN_EMAIL=admin@example.com
APR_ADMIN_PASSWORD_HASH=replace-with-output-of-npm-run-hash-password
APR_MASTER_API_KEY=replace-with-32-plus-random-characters
APR_INGEST_API_KEY=replace-with-an-ingest-only-random-key
APR_SESSION_SECRET=replace-with-32-plus-random-characters
APR_USER_ID_HMAC_SECRET=replace-with-a-distinct-32-plus-random-secret

APR_CORS_ORIGINS=
APR_WORKER_ENABLED=true
APR_WORKER_INTERVAL_MS=60000
APR_ALERT_WEBHOOK_URL=
APR_ALERT_FEISHU_WEBHOOK_URL=
