{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-product-reliability-kit.local/schemas/product-contract.schema.json",
  "title": "AI Product Reliability Product Contract",
  "type": "object",
  "required": ["standard_version", "product", "environments", "critical_journeys", "health", "release"],
  "additionalProperties": true,
  "properties": {
    "standard_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "product": {
      "type": "object",
      "required": ["id", "name", "owner"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        }
      }
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["local", "development", "staging", "production"]
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "critical_journeys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "success_event"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_/-]*$"
          },
          "name": {
            "type": "string"
          },
          "success_event": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "failure_event": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "synthetic_check": {
            "type": "string"
          }
        }
      }
    },
    "health": {
      "type": "object",
      "required": ["live_path"],
      "properties": {
        "live_path": {
          "type": "string",
          "default": "/healthz"
        },
        "ready_path": {
          "type": "string",
          "default": "/readyz"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "release": {
      "type": "object",
      "required": ["version_source", "rollback"],
      "properties": {
        "version_source": {
          "type": "string",
          "examples": ["git_sha", "package_version", "container_tag"]
        },
        "rollback": {
          "type": "string"
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    }
  }
}

